# RPC endpoint for Ethereum Sepolia. The public endpoint works, or use an Alchemy or Infura url.
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Private key of a Sepolia account funded with test ETH. Required for deployment.
# Accepted with or without the 0x prefix. Never commit the real value.
DEPLOYER_PRIVATE_KEY=
